# ---- Monad testnet ----
MONAD_RPC=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
EXPLORER_URL=https://testnet.monadexplorer.com

# Backend / deployer wallet (custodial demo hires + faucet). Needs testnet MON for gas.
DEPLOYER_PRIVATE_KEY=0x...
# Auditor wallet — the ONLY key allowed to call Resolver.resolve (the on-chain oracle).
AUDITOR_PRIVATE_KEY=0x...
# Protocol fee sink (defaults to the deployer address if unset).
TREASURY_ADDRESS=

# ---- Worker LLM (auditor is deterministic where there's on-chain ground truth) ----
# Provider auto-selected: groq if GROQ_API_KEY set, else anthropic, else deterministic.
LLM_PROVIDER=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
WORKER_MODEL=claude-sonnet-4-6

# ---- Server ----
PORT=8787

# ---- Contract verification (optional) ----
EXPLORER_API_KEY=
EXPLORER_API_URL=
